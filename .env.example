# ============================================================
# .env.example — TEMPLATE ONLY. Copy to .env and fill values.
# ============================================================
# HOW TO USE:
#   Copy this file to .env and replace the placeholder with your real key.
#
# GET YOUR KEY:
#   https://dashboard.api-football.com/profile?access
#
# SECURITY REMINDER:
#   .env is in .gitignore and will NEVER be committed.
#   This .env.example file IS committed — it has no real secrets.
# ============================================================

API_FOOTBALL_KEY=your_api_key_here
API_FOOTBALL_HOST=v3.football.api-sports.io
API_BASE_URL=https://v3.football.api-sports.io

# Optional: set to "true" to force re-fetch even if cache exists
FORCE_REFETCH=false

# Optional: log level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO